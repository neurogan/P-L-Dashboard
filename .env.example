# ── PostgreSQL (required) ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/neurogan?schema=pl_dashboard

# ── Session secret (required) ────────────────────────────────────────────
SESSION_SECRET=change-me

# ── Amazon SP-API (optional — for order ingestion) ───────────────────────
AMAZON_SP_API_CLIENT_ID=
AMAZON_SP_API_CLIENT_SECRET=
AMAZON_SP_API_REFRESH_TOKEN=
AMAZON_SP_API_MARKETPLACE_ID=ATVPDKIKX0DER

# ── Amazon Advertising (optional — for ad data ingestion) ────────────────
AMAZON_ADS_CLIENT_ID=
AMAZON_ADS_CLIENT_SECRET=
AMAZON_ADS_REFRESH_TOKEN=
AMAZON_ADS_PROFILE_ID=

# ── MarketplaceAdPros (alternative to Amazon Ads API) ────────────────────
MARKETPLACE_AD_PROS_API_KEY=
MARKETPLACE_AD_PROS_ACCOUNT_ID=

# ── Shopify (optional — for DTC / Faire order ingestion) ─────────────────
SHOPIFY_STORE_URL=yourstore.myshopify.com
SHOPIFY_ACCESS_TOKEN=

# ── QuickBooks Online (optional — for COGS ingestion) ────────────────────
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REFRESH_TOKEN=
QBO_REALM_ID=
QBO_ENVIRONMENT=production
